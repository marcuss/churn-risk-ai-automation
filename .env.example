# Copy to .env and fill in. NEVER commit .env — it is git-ignored.

# Anthropic API key used for summary generation.
ANTHROPIC_API_KEY=

# Slack incoming webhook the weekly briefing is POSTed to.
SLACK_WEBHOOK_URL=

# Optional — model used for summaries (default: claude-sonnet-4-6).
ANTHROPIC_MODEL=claude-sonnet-4-6
